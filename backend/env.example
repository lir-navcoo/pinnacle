# Pinnacle 后端环境配置示例

# ===== 应用配置 =====
APP_NAME=Pinnacle
APP_VERSION=0.1.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# ===== 数据库配置（MySQL）=====
# 格式：mysql+aiomysql://用户名:密码@主机：端口/数据库名
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/pinnacle

# ===== Redis 配置 =====
REDIS_URL=redis://localhost:6379/0

# ===== JWT 配置 =====
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===== 文件存储配置 =====
# 存储类型：local（本地） | oss（阿里云 OSS）
STORAGE_TYPE=local

# 本地存储路径
LOCAL_STORAGE_PATH=/Users/lirui/Documents/pinnacle/backend/uploads
# 本地存储访问 URL 前缀
LOCAL_STORAGE_URL_PREFIX=/uploads

# ===== 阿里云 OSS 配置（可选，当 STORAGE_TYPE=oss 时使用）=====
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=pinnacle
OSS_REGION=cn-hangzhou

# ===== 钉钉机器人配置（可选）=====
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=

# ===== CORS 跨域配置 =====
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== 渲染配置 =====
RENDER_CACHE_TTL=3600
MAX_IMAGE_SIZE=10485760
DEFAULT_IMAGE_FORMAT=PNG
DEFAULT_IMAGE_QUALITY=95
